  <question type="multichoiceset">
    <name>
      <text>Pandas 行・列・欠損値処理</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p dir="ltr" style="text-align: left;">次の説明のうち正しいものはどれか．すべて選べ．<br>ただし，dfはデータフレームを表す変数とし，pdはpandasライブラリを参照する変数とする．</p>]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text></text>
    </generalfeedback>
    <defaultgrade>1.0000000</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <idnumber></idnumber>
    <shuffleanswers>true</shuffleanswers>
    <correctfeedback format="html">
