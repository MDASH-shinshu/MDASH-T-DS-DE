    <answernumbering>abc</answernumbering>
    <showstandardinstruction>0</showstandardinstruction>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="ltr" style="text-align: left;">df["A"] = df["A"].astype(int) は列 A を整数型に変換する．</p>]]></text>
      <feedback format="html">
        <text></text>
      </feedback>
    </answer>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="ltr" style="text-align: left;">df["C"] = pd.to_datetime(df["C"]) は列 C の日付文字列を日付型に変換する．</p>]]></text>
      <feedback format="html">
        <text></text>
      </feedback>
    </answer>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="ltr" style="text-align: left;">df.dropna(subset=["A","B"]) は列 A または B に欠損がある行を削除する．</p>]]></text>
      <feedback format="html">
        <text></text>
      </feedback>
    </answer>
    <answer fraction="100" format="html">
      <text><![CDATA[<p dir="ltr" style="text-align: left;">df.fillna(df.mean(numeric_only=True)) は各「数値列」の平均で，その列の欠損を埋める．</p>]]></text>
